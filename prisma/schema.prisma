generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Company {
  id         String   @id @default(uuid())
  slug       String   @unique
  name       String
  logo_url   String?
  plan       Plan     @default(FREE)
  active     Boolean  @default(true)
  created_at DateTime @default(now())

  users           User[]
  seller_profiles SellerProfile[]
  products        Product[]
  categories      ProductCategory[]
  panel_contents  PanelContent[]
  coupon_packs    CouponPack[]
  support_tickets SupportTicket[]

  @@map("companies")
}

enum Plan {
  FREE
  PRO
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password_hash String?
  role          Role     @default(SELLER)
  company_id    String?
  created_at    DateTime @default(now())

  company        Company?       @relation(fields: [company_id], references: [id])
  seller_profile SellerProfile?
  coupon_packs   CouponPack[]

  @@map("users")
}

enum Role {
  SUPERADMIN
  COMPANY_ADMIN
  SELLER
}

model SellerProfile {
  id         String   @id @default(uuid())
  user_id    String   @unique
  company_id String
  slug       String
  name       String
  photo_url  String?
  whatsapp   String?
  instagram  String?
  youtube    String?
  tiktok     String?
  facebook   String?
  other_link String?
  other_link_label String?
  city       String?
  state      String?
  bio        String?
  signup_button_text String? @default("Fazer cadastro")
  signup_button_url  String? @default("https://cadastro.atlanticanatural.com.br/codigos")
  active     Boolean  @default(true)
  status     SellerStatus @default(PENDING)
  created_at DateTime @default(now())

  user          User           @relation(fields: [user_id], references: [id])
  company       Company        @relation(fields: [company_id], references: [id])
  subscriptions Subscription[]
  coupons_used  Coupon[]
  support_tickets SupportTicket[]

  @@unique([company_id, slug])
  @@map("seller_profiles")
}

enum SellerStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

model Subscription {
  id           String             @id @default(uuid())
  seller_id    String
  status       SubscriptionStatus @default(ACTIVE)
  activated_at DateTime           @default(now())
  expires_at   DateTime
  coupon_id    String?            @unique
  notes        String?

  seller SellerProfile @relation(fields: [seller_id], references: [id])
  coupon Coupon?       @relation(fields: [coupon_id], references: [id])

  @@map("subscriptions")
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

model CouponPack {
  id         String   @id @default(uuid())
  buyer_id   String
  company_id String
  quantity   Int      @default(10)
  notes      String?
  type       PackType @default(ANNUAL)
  created_at DateTime @default(now())

  buyer   User      @relation(fields: [buyer_id], references: [id])
  company Company   @relation(fields: [company_id], references: [id])
  coupons Coupon[]

  @@map("coupon_packs")
}

enum PackType {
  ANNUAL
  PROMOTIONAL
}

model ImpersonationToken {
  id         String   @id @default(uuid())
  token      String   @unique
  admin_id   String
  seller_id  String
  used       Boolean  @default(false)
  expires_at DateTime
  created_at DateTime @default(now())

  @@map("impersonation_tokens")
}

model SupportTicket {
  id         String       @id @default(uuid())
  company_id String
  seller_id  String
  subject    String
  message    String
  status     TicketStatus @default(OPEN)
  created_at DateTime     @default(now())

  company Company       @relation(fields: [company_id], references: [id])
  seller  SellerProfile @relation(fields: [seller_id], references: [id])

  @@map("support_tickets")
}

enum TicketStatus {
  OPEN
  RESOLVED
}

model Coupon {
  id         String    @id @default(uuid())
  pack_id    String
  code       String    @unique
  used_by    String?
  used_at    DateTime?
  expires_at DateTime?
  created_at DateTime  @default(now())

  pack         CouponPack     @relation(fields: [pack_id], references: [id])
  seller       SellerProfile? @relation(fields: [used_by], references: [id])
  subscription Subscription?

  @@map("coupons")
}

model ProductCategory {
  id         String  @id @default(uuid())
  company_id String
  name       String
  sort_order Int     @default(0)

  company  Company   @relation(fields: [company_id], references: [id])
  products Product[]

  @@unique([company_id, name])
  @@map("product_categories")
}

model Product {
  id               String   @id @default(uuid())
  company_id       String
  category_id      String?
  code             String
  name             String
  description      String?
  price_consultant Decimal? @db.Decimal(10, 2)
  price_client     Decimal? @db.Decimal(10, 2)
  image_url        String?
  catalog_image_url String?
  catalog_page      Int?
  catalog_page_file String?
  active           Boolean  @default(true)
  sort_order       Int      @default(0)
  created_at       DateTime @default(now())

  company  Company          @relation(fields: [company_id], references: [id])
  category ProductCategory? @relation(fields: [category_id], references: [id])

  @@unique([company_id, code])
  @@map("products")
}

model PanelContent {
  id         String      @id @default(uuid())
  company_id String
  type       ContentType
  title      String
  content    String?
  url        String?
  sort_order Int         @default(0)
  active     Boolean     @default(true)
  created_at DateTime    @default(now())

  company Company @relation(fields: [company_id], references: [id])

  @@map("panel_contents")
}

enum ContentType {
  TUTORIAL
  VIDEO
  PROTOCOL
  SALES_PAGE
  SUPPORT
}